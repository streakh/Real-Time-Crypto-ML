{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Active model variant",
      "id": 1,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "model_variant_active == 1",
          "legendFormat": "{{model_variant}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "mappings": []}
      }
    },
    {
      "type": "stat",
      "title": "p95 latency (s)",
      "id": 2,
      "gridPos": {"h": 4, "w": 9, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(predict_latency_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 0.8}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "p50 latency (s)",
      "id": 3,
      "gridPos": {"h": 4, "w": 9, "x": 15, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(predict_latency_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "Request rate (req/s) by variant",
      "id": 4,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum by (model_variant) (rate(predict_requests_total[1m]))",
          "legendFormat": "{{model_variant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "timeseries",
      "title": "Error rate (errors/req) by variant",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "sum by (model_variant) (rate(predict_errors_total[5m])) / clamp_min(sum by (model_variant) (rate(predict_requests_total[5m])), 0.001)",
          "legendFormat": "{{model_variant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },
    {
      "type": "timeseries",
      "title": "Kafka consumer lag (ticks.raw)",
      "id": 6,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "sum by (consumergroup) (kafka_consumergroup_lag{topic=\"ticks.raw\"})",
          "legendFormat": "{{consumergroup}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["btc", "volatility", "api"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "BTC Volatility Detector — API",
  "uid": "btc-vol-api",
  "version": 1,
  "weekStart": ""
}
