FROM python:3.11-slim

WORKDIR /app

# Install only what the API needs
COPY docker/requirements.api.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy app code and model artifacts
COPY api/ api/
COPY handoff/models/artifacts/ models/artifacts/

ENV MODEL_PATH=models/artifacts/lr_pipeline.pkl

EXPOSE 8000

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
