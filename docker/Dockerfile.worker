FROM python:3.11-slim

WORKDIR /app

COPY docker/requirements.worker.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY features/ features/
COPY scripts/ scripts/
COPY config.yaml .

# featurizer.py does `from feature_funcs import ...` (flat imports)
ENV PYTHONPATH=/app/features
ENV PYTHONUNBUFFERED=1

CMD ["python", "-u", "features/featurizer.py", "--config", "/app/config.yaml"]
