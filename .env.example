# Optional overrides for docker-compose.yaml and the helper scripts.
# The root stack already has working defaults, so .env is only needed if you
# want to change them.
# NEVER commit .env to version control.

# Root stack defaults used by the canonical `docker compose up -d` path.
REPLAY_SPEED=1.0
MODEL_VARIANT=ml
BASELINE_VOL_THRESHOLD=0.000048
MODEL_NAME=btc-volatility-lr
MODEL_STAGE=Production
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Advanced Docker-internal overrides.
# These values are normally correct as-is for the compose-managed stack, but the
# runtime reads them directly so they are documented here for completeness.
KAFKA_BOOTSTRAP=kafka:29092
TOPIC_RAW=ticks.raw
TOPIC_FEATURES=ticks.features
KAFKA_GROUP_ID=predict-bridge
PREDICT_API_URL=http://api:8000/predict
PREDICT_API_HEALTH_URL=http://api:8000/health
PREDICT_API_TIMEOUT=10
STARTUP_TIMEOUT=30
RETRY_BACKOFF=2
MODEL_PATH=models/artifacts/lr_pipeline.pkl
MODEL_VERSION=v1.0

# Local-shell helpers for running scripts outside Docker.
# The root compose stack does not use these because compose wires Kafka and
# MLflow to internal service addresses directly.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MLFLOW_TRACKING_URI=http://localhost:5001

# Optional metadata/debug injection.
# The API computes the short git SHA from the repository when available; this is
# only used as an override when git metadata is unavailable at startup.
GIT_SHA=unknown

# Note: ws_ingest.py uses the public Coinbase advanced-trade-ws ticker channel,
# which requires no authentication. No API keys are needed to run live mode.
