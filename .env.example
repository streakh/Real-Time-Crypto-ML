# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# Kafka bootstrap (default: local Docker service)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# API settings
MODEL_PATH=models/artifacts/lr_pipeline.pkl
MODEL_VERSION=v1.0

# Rollback toggle: ml (LR pipeline) or baseline (vol_60s threshold rule)
MODEL_VARIANT=ml
BASELINE_VOL_THRESHOLD=0.000048

# Grafana (anonymous viewer is enabled; admin login uses these creds)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Coinbase Advanced Trade API (optional – only needed for authenticated channels)
# COINBASE_API_KEY=your_api_key_here
# COINBASE_API_SECRET=your_api_secret_here
