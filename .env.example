# Optional overrides for docker-compose.yaml.
# The root stack already has working defaults, so .env is only needed if you
# want to change them.
# NEVER commit .env to version control.

# Replay ingestor setting consumed by the root compose stack.
REPLAY_SPEED=1.0

# API / MLflow registry settings consumed by the root compose stack.
# MLFLOW_TRACKING_URI is wired internally in Docker as http://mlflow:5000.
MODEL_VARIANT=ml
BASELINE_VOL_THRESHOLD=0.000048
MODEL_NAME=btc-volatility-lr
MODEL_STAGE=Production

# Grafana admin credentials for the root compose stack.
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Local-only helpers for running scripts outside Docker from your shell.
# The root compose stack does not read these because it wires Kafka and MLflow
# to internal Docker service addresses directly.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MLFLOW_TRACKING_URI=http://localhost:5001

# MODEL_PATH and MODEL_VERSION are fixed in docker-compose.yaml.

# Note: ws_ingest.py uses the public Coinbase advanced-trade-ws ticker channel,
# which requires no authentication. No API keys are needed to run live mode.
