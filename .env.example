# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# Kafka bootstrap (default: local Docker service)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# API settings
MODEL_PATH=models/artifacts/lr_pipeline.pkl
MODEL_VERSION=v1.0

# Rollback toggle: ml (LR pipeline) or baseline (vol_60s threshold rule)
MODEL_VARIANT=ml
BASELINE_VOL_THRESHOLD=0.000048

# Replay speed multiplier for the ingestor (1.0 = real-time, increase in CI to fast-forward)
REPLAY_SPEED=1.0

# MLflow model registry (use http://mlflow:5001 inside Docker; localhost outside)
MLFLOW_TRACKING_URI=http://mlflow:5001
MODEL_NAME=btc-volatility-lr
MODEL_STAGE=Production

# Grafana (anonymous viewer is enabled by default; admin login uses these creds)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Note: ws_ingest.py uses the public Coinbase advanced-trade-ws ticker channel,
# which requires no authentication. No API keys are needed to run live mode.
